# =============================================================================
# ImmoNiq – Environment Variables (Beispiel)
# =============================================================================
# Diese Datei dient nur als Vorlage. Echte Werte stehen in `.env` (auto-managed
# von Lovable Cloud) und dürfen NICHT eingecheckt werden.
#
# Alle VITE_*-Variablen sind PUBLISHABLE Keys – sie landen sowieso im
# Frontend-Bundle. Geheime Schlüssel (Service Role, Stripe Secret, etc.)
# gehören NICHT hierher, sondern in die Lovable Cloud Secrets.
# =============================================================================

# Supabase / Lovable Cloud (publishable)
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-key>"
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# Optional – nur für lokale Overrides
# VITE_APP_ENV="development"
